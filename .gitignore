node_modules/
dist/
package-lock.json
.npmrc
*.sqlite
.DS_Store
archive/
texts/
.cursor/
.github/copilot/
.claude/
.vscode/
.serena/
graphify-out/

# Python
__pycache__/
*.pyc
*.pyo

# Tool working state — vexp MCP server, pi config, serena. All auto-regenerated
# by the local tools; tracking them pollutes PRs with tool noise.
.vexp/
.pi/
.serena/

# Markdown — only allow tracked top-level docs and curated subdirs.
# (root *.md is ignored by default; explicitly track the ones below.)
*.md
!README.md
!CLAUDE.md
!CHANGELOG.md
!skills/**/*.md
!docs/**/*.md
!devnotes/**/*.md
!evaluate/**/*.md
!setup/**/*.md
!test/**/*.md

# Evaluation artifacts (sqlite + per-tag results + LLM cache + run logs)
evaluate/locomo/debug-*.mjs
evaluate/locomo/dbs/
evaluate/locomo/results.json
evaluate/locomo/results-*.json
evaluate/locomo/locomo10.json
evaluate/locomo/llm-cache.json
evaluate/locomo/**/*.log
evaluate/longmemeval/longmemeval_*.json
evaluate/longmemeval/dbs/
evaluate/longmemeval/results*.json
evaluate/longmemeval/llm-cache.json
evaluate/longmemeval/**/*.log
evaluate/sweeps/*/
!evaluate/sweeps/configs/
