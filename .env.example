# Lotl Environment Variables — canonical reference
# ==================================================
# Copy to ~/.config/lotl/.env and fill in what you need.
# Loaded automatically at startup via src/env.ts — no source needed.
#
# Naming convention: LOTL_{OPERATION}_{ATTRIBUTE}
#   OPERATION = EMBED | RERANK | QUERY_EXPANSION | MEMORY | INGEST |
#               JUDGE | LMSTUDIO | ANSWER | PROMPT | EVAL | LOCOMO | LME
#   ATTRIBUTE = PROVIDER | URL | API_KEY | MODEL | BACKEND | DIMENSIONS
#
# Most operations follow the same pattern: PROVIDER + URL + API_KEY + MODEL.
# For OpenAI-compatible endpoints (OpenAI, Ollama, vLLM, LM Studio, Lemonade),
# use PROVIDER=api and set URL to the local server's /v1 base. See the
# "Local-LLM URL examples" block at the bottom for copy-paste defaults.
#
# Eval-harness-only vars use the LOTL_EVAL_* prefix. A startup compat
# bridge (evaluate/shared/env-compat.ts) mirrors LOTL_EVAL_X ↔ LOTL_X for
# the migration window so legacy scripts keep working.


# ======================================================================
# ⭐ Quick-start: local embed, beats MemPalace 96.6% LongMemEval _s by 1.8pp
# ======================================================================
# Copy these 4 lines and you're done. Everything else is optional tuning.
#
# LOTL_EMBED_BACKEND=transformers
# LOTL_EMBED_MODEL=mixedbread-ai/mxbai-embed-xsmall-v1
# LOTL_TRANSFORMERS_DTYPE=q8
# LOTL_VEC_MIN_SIM=0.1


# ======================================================================
# Embed — vector generation for memory recall
# ======================================================================
# LOTL_EMBED_API_KEY           sk-...                                (required for remote providers)
# LOTL_EMBED_BACKEND           transformers | remote | lmstudio      (default: remote)
#                              "transformers" = local ONNX
#                              "lmstudio"     = LM Studio /v1/embeddings (GGUF embedders)
#                              "remote"       = API via LOTL_EMBED_PROVIDER
# LOTL_EMBED_DIMENSIONS        384                                   (auto-detected from first embed)
# LOTL_EMBED_DIRECT            on                                    (direct-ORT path — required for jina-v5)
# LOTL_EMBED_MODEL             mixedbread-ai/mxbai-embed-xsmall-v1   (default)
# LOTL_EMBED_PASSAGE_PREFIX    "search_document: "                   (auto-set per model family)
# LOTL_EMBED_PROVIDER          api | url | gemini                    (remote-only)
#                              api    = OpenAI-compatible /v1 base URL (works for OpenAI, Ollama, vLLM, LM Studio, Lemonade)
#                              url    = full custom endpoint
#                              gemini = Google's embedContent API (different wire shape)
# LOTL_EMBED_QUERY_PREFIX      "search_query: "                      (auto-set per model family)
# LOTL_EMBED_URL               https://api.openai.com/v1             (base URL when PROVIDER=api)

# Local ONNX (LOTL_EMBED_BACKEND=transformers)
# LOTL_TRANSFORMERS_AUTO_PREFER  cpu                                  (override GPU-first in auto mode)
# LOTL_TRANSFORMERS_CACHE_DIR    ~/.cache/lotl/transformers            (model cache path)
# LOTL_TRANSFORMERS_DEVICE       auto | cpu | webgpu | dml             (default: cpu)
# LOTL_TRANSFORMERS_DTYPE        q8 | fp16 | fp32 | q4 | int8 | uint8  (default: q8)
# LOTL_TRANSFORMERS_FILE         model_quint8_avx2                     (optional file override)


# ======================================================================
# Rerank — cross-encoder reranking (optional)
# ======================================================================
# LOTL_MEMORY_RERANK                     on                           (enable rerank; default off)
# LOTL_RERANK_API_KEY                    sk-...                       (required for remote providers)
# LOTL_RERANK_BACKEND                    transformers | remote | lmstudio  (default: transformers)
# LOTL_RERANK_MODE                       llm | rerank                 (llm=chat-based; rerank=cross-encoder)
# LOTL_RERANK_MODEL                      jinaai/jina-reranker-v1-tiny-en   (Stage 9 winner; default for local)
# LOTL_RERANK_PROVIDER                   api | url | gemini           (remote only — same shape as embed)
# LOTL_RERANK_STRONG_SIGNAL_SKIP         on                           (skip rerank when vec/fts agree strongly)
# LOTL_RERANK_URL                        https://...                  (base URL)

# Local rerank via @huggingface/transformers
# LOTL_TRANSFORMERS_RERANK            jinaai/jina-reranker-v1-tiny-en  (composite alias — local rerank model)
# LOTL_TRANSFORMERS_RERANK_DTYPE      q8
# LOTL_TRANSFORMERS_RERANK_FILE       (optional file override)
# LOTL_TRANSFORMERS_RERANK_MAXLEN     512                              (tokenizer truncation cap. Prevents the
#                                                                      ModernBERT-class OOM where uncapped
#                                                                      8192-token context allocated 67 GB for
#                                                                      a single MatMul. Raise only if you know
#                                                                      the reranker needs >512 tokens.)
# LOTL_TRANSFORMERS_RERANK_MODEL      jinaai/jina-reranker-v1-tiny-en

# LM Studio rerank (LOTL_RERANK_BACKEND=lmstudio; GGUF rerankers via chat-completions shim)
# LOTL_LMSTUDIO_RERANK_MODEL          qwen3-reranker-0.6b              (LM Studio model ID)
# LOTL_LMSTUDIO_RERANK_WORKERS        4                                (parallel scoring workers)


# ======================================================================
# Memory — recall tuning, fusion weights, knowledge graph
# ======================================================================
# LOTL_MEMORY_EMBED_SOURCE     content | fact   (default: content. "fact" uses the Phase-5b
#                                                fact_embedding column populated by
#                                                evaluate/scripts/extract-facts-batch.mjs)
# LOTL_MEMORY_EXPAND           keywords | entities | none
#                                                (zero-LLM query expansion. Default: keywords.)
# LOTL_MEMORY_KG               on               (KG fact injection on weak recall; default off.
#                                                Requires KG populated via extract-facts-batch.)
# LOTL_MEMORY_RRF_W_BM25       0.8              (BM25 weight in RRF fusion. LME n=500 winner.)
# LOTL_MEMORY_RRF_W_VEC        0.2              (vector weight. Vec-heavy regresses with mxbai-xs;
#                                                revisit when a stronger embedder lands.)


# ======================================================================
# Recall pipeline — production-relevant only
# ======================================================================
# LOTL_RECALL_NO_TOUCH         on        (skip recall-time access_count increment.
#                                          Eval default: ON. Production: OFF — touches drive
#                                          decay/promotion. Baked into evaluate/*/eval.mts.)
# LOTL_RECALL_PROFILE          on        (per-stage timing profile to stderr — dev tool)
# LOTL_RECALL_RAW              on        (skip post-fusion boosts — eval baselines only)
# LOTL_REFLECT_MAX_CHARS       800       (per-memory char cap during reflection)
# LOTL_REFLECT_TOP_K           10        (max memories fed to reflection step)


# ======================================================================
# Ingest — eval-harness ablations (guards optional preprocessing)
# ======================================================================
# Read by evaluate/*/eval.mts only — not by the runtime SDK. Default = all enabled.
# Set =off in sweep scripts for simpler baseline timing. Likely consolidated post-v1.0.
# LOTL_INGEST_BATCH_EXTRACT      on|off
# LOTL_INGEST_EXTRACTION         on|off
# LOTL_INGEST_PER_TURN           on|off
# LOTL_INGEST_SESSION_AS_MEMORY  on|off
# LOTL_INGEST_SYNTHESIS          on|off
# LOTL_INGEST_USER_ONLY          on|off    (L1: user turns only at embed time)


# ======================================================================
# Query expansion (optional, improves recall on vague queries)
# ======================================================================
# LOTL_QUERY_EXPANSION_API_KEY   sk-...                              (required for remote providers)
# LOTL_QUERY_EXPANSION_MODEL     qwen2.5-7b-instruct                 (any OpenAI-compat chat model)
# LOTL_QUERY_EXPANSION_PROVIDER  api | url | gemini                  (same shape as embed/rerank)
# LOTL_QUERY_EXPANSION_URL       https://...


# ======================================================================
# Chunking + vector floor
# ======================================================================
# LOTL_CHUNK_SIZE_TOKENS       900    (default chunk size in tokens — seldom flipped)
# LOTL_CHUNK_WINDOW_TOKENS     200    (overlap window — seldom flipped)
# LOTL_VEC_MIN_SIM             0.1    (fixed cosine floor — recommended, overrides adaptive.
#                                       Worth re-measuring on any embedder swap.)


# ======================================================================
# General runtime
# ======================================================================
# LOTL_CONFIG_DIR              ~/.config/lotl     (config location override)
# LOTL_EDITOR_URI              vscode://file/%s   (custom editor URI template)
# LOTL_LLM_CACHE               /path/to/cache     (LLM response cache, reproducibility)
# LOTL_LLM_CACHE_PATH          /path/to/cache     (alias of LOTL_LLM_CACHE)
# LOTL_LOCAL                   on                 (force local-only mode)
# LOTL_SKILL_BASE              /path/to/skills    (custom skill install base)
# LOTL_TIMEOUT_MS              30000              (default request timeout)


# ======================================================================
# Eval-only — answer / prompt / judge / LoCoMo / LME
# ======================================================================
# Read only by evaluate/*/eval.mts. New scripts use LOTL_EVAL_* prefix;
# the compat bridge (evaluate/shared/env-compat.ts) mirrors LOTL_X ↔
# LOTL_EVAL_X for the 30-ish eval-only names while scripts migrate.

# Answer generation + caching
# LOTL_ANSWER_CACHE            on                                     (persist generated answers)
# LOTL_ANSWER_CACHE_DIR        evaluate/longmemeval/answer-cache      (cache location)
# LOTL_ANSWER_MAX_CHARS        6000                                   (LongMemEval per-memory char cap)
# LOTL_ANSWER_MAX_TOKENS       (model default)                        (per-answer token cap)
# LOTL_ANSWER_TOP_K            10                                     (memories fed to generator;
#                                                                      aligns with Mem0/MemOS/EverMemOS/Zep)

# Prompt selection
# LOTL_PROMPT_RULES            v11                                    (v11 default · v13 minimal · v14 = 7-step CoT
#                                                                      ported from locomo-audit repo)

# Judge (eval-only LLM verdict call)
# LOTL_JUDGE_API_KEY           sk-...
# LOTL_JUDGE_MAX_TOKENS        96                                     (auto-raised to 768 for lmstudio)
# LOTL_JUDGE_MODEL             gpt-4o
# LOTL_JUDGE_RUNS              1                                      (N-run majority vote; 3 for audit-rigor)
# LOTL_JUDGE_TEMPERATURE       0
# LOTL_JUDGE_TIMEOUT_MS        30000
# LOTL_JUDGE_URL               https://api.poe.com/v1

# LoCoMo + LongMemEval
# LOTL_LME_WORKERS             2                                      (parallel workers for LongMemEval loop)
# LOTL_LOCOMO_ANSWER_TOP_K     10                                     (LoCoMo: memories fed to generator)
# LOTL_LOCOMO_JUDGE            lenient | strict                       ('strict' drops audit's 6.9× leniency)
# LOTL_LOCOMO_WORKERS          1                                      (parallel workers — match LM Studio slots)

# Fact extraction batch (populates memories.fact_text / fact_embedding)
# LOTL_EXTRACT_MAX_TOKENS      512

# Misc eval
# LOTL_EVAL_PARTIAL_EVERY      10                                     (save partial results every N questions)
# LOTL_POE_MODEL               gpt-4o-mini                            (Poe endpoint model)
# LOTL_SKIP_PREFLIGHT          on                                     (skip API quota preflight probe)


# ======================================================================
# LM Studio local LLM (OpenAI-compatible) — no API key required, any placeholder works
# ======================================================================
# LOTL_LMSTUDIO_HOST           10.0.0.105:1234                         (host:port of LM Studio server)
# LOTL_LMSTUDIO_KEY            lm-studio                               (placeholder)
# LOTL_LMSTUDIO_GEN_MODEL      meta-llama-3.1-8b-instruct              (loaded for answer generation)
# LOTL_LMSTUDIO_JUDGE_MODEL    qwen/qwen3.6-35b-a3b                    (loaded for judge pass)
# LOTL_LMSTUDIO_EMBED_MODEL    text-embedding-embeddinggemma-300m      (loaded when LOTL_EMBED_BACKEND=lmstudio)
# LOTL_LMSTUDIO_EMBED_BATCH    32                                      (requests per /v1/embeddings batch)
#
# Context + parallel slots — collapsed to one pair for gen, one for judge.
# Per-prompt-version specifics live inside the smoke scripts (V11 vs V14 ctx
# math), not as user-facing knobs. context_length is TOTAL across slots:
# per-slot ≈ context_length / parallel.
# LOTL_LMSTUDIO_CTX_GEN          98304                                 (total ctx across gen slots)
# LOTL_LMSTUDIO_PARALLEL_GEN     8                                     (parallel slots for gen)
# LOTL_LMSTUDIO_CTX_JUDGE        32768                                 (total ctx across judge slots)
# LOTL_LMSTUDIO_PARALLEL_JUDGE   1                                     (parallel slots for judge)


# ======================================================================
# API keys (per-provider — REQUIRED for respective providers)
# ======================================================================
# GOOGLE_API_KEY=AIza...             (for LOTL_EMBED_PROVIDER=gemini / --llm gemini)
# MINIMAX_API_KEY=eyJ...             (for --llm minimax)
# OPENAI_API_KEY=sk-...              (for LOTL_EMBED_PROVIDER=api with OpenAI)
# POE_API_KEY=psk_...                (for --llm poe / --judge poe)


# ======================================================================
# Local-LLM URL examples (PROVIDER=api, set URL to one of these)
# ======================================================================
# OpenAI:                LOTL_{OP}_URL=https://api.openai.com/v1
# Ollama:                LOTL_{OP}_URL=http://localhost:11434/v1
# vLLM:                  LOTL_{OP}_URL=http://localhost:8000/v1
# LM Studio:             LOTL_{OP}_URL=http://localhost:1234/v1
# Lemonade (AMD):        LOTL_{OP}_URL=http://localhost:8000/api/v1
#
# All local servers above accept LOTL_{OP}_API_KEY unset or any placeholder.
# Replace {OP} with EMBED, RERANK, QUERY_EXPANSION, or JUDGE.
#
# Example — query expansion via local Ollama:
#   LOTL_QUERY_EXPANSION_PROVIDER=api
#   LOTL_QUERY_EXPANSION_URL=http://localhost:11434/v1
#   LOTL_QUERY_EXPANSION_MODEL=qwen2.5:7b-instruct
