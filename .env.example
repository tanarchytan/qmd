# Lotl Environment Variables — canonical reference
# ==================================================
# Copy to ~/.config/lotl/.env and fill in what you need.
# Loaded automatically at startup via src/env.ts — no source needed.
#
# Naming convention: LOTL_{OPERATION}_{ATTRIBUTE}
#   OPERATION = EMBED | RERANK | QUERY_EXPANSION | MEMORY | INGEST | RECALL | ...
#   ATTRIBUTE = PROVIDER | URL | API_KEY | MODEL | BACKEND | DIMENSIONS | ...


# ======================================================================
# ⭐ Quick-start: local embed, beats MemPalace 96.6% LongMemEval _s by 1.8pp
# ======================================================================
# Copy these 4 lines and you're done. Everything else is optional tuning.
#
# LOTL_EMBED_BACKEND=transformers
# LOTL_EMBED_MODEL=mixedbread-ai/mxbai-embed-xsmall-v1
# LOTL_TRANSFORMERS_DTYPE=q8
# LOTL_VEC_MIN_SIM=0.1


# ======================================================================
# Embed — vector generation for memory recall
# ======================================================================
# LOTL_EMBED_BACKEND           transformers | remote               (default: remote)
#                             "transformers" = local ONNX via @huggingface/transformers
#                             "remote"       = API via LOTL_EMBED_PROVIDER below
# LOTL_EMBED_PROVIDER          api | url | gemini | ollama | vllm | lm-studio | lemonade
#                             (remote-only; ignored when backend=transformers)
# LOTL_EMBED_URL               https://api.openai.com/v1            (base URL for 'api' provider)
# LOTL_EMBED_API_KEY           sk-...                                (optional for local provider shorthands)
# LOTL_EMBED_MODEL             mixedbread-ai/mxbai-embed-xsmall-v1   (default)
# LOTL_EMBED_DIMENSIONS        384                                   (auto-detected from first embed)
# LOTL_EMBED_QUERY_PREFIX      "search_query: "                      (auto-set per model family)
# LOTL_EMBED_PASSAGE_PREFIX    "search_document: "                   (auto-set per model family)
# LOTL_EMBED_MICROBATCH        (auto — sized by src/llm/embed-sizer.ts)
# LOTL_EMBED_MAX_WORKERS       (auto — sized by src/llm/embed-sizer.ts)
# LOTL_EMBED_DIRECT            on                                    (enable direct-ORT path — required for jina-v5)

# Local-only ONNX via @huggingface/transformers (LOTL_EMBED_BACKEND=transformers)
# LOTL_TRANSFORMERS_DTYPE        q8 | fp16 | fp32 | q4 | int8 | uint8   (default: q8)
# LOTL_TRANSFORMERS_FILE         model_quint8_avx2                      (optional file override)
# LOTL_TRANSFORMERS_DEVICE       auto | cpu | webgpu | dml              (default: cpu)
# LOTL_TRANSFORMERS_AUTO_PREFER  cpu                                    (overrides GPU-first in auto mode)
# LOTL_TRANSFORMERS_CACHE_DIR    ~/.cache/lotl/transformers              (model cache path)
# LOTL_TRANSFORMERS_QUIET        on                                     (suppress load-info stderr)

# Direct-ORT path (LOTL_EMBED_DIRECT=on — for models whose model_type isn't in transformers.js)
# LOTL_TRANSFORMERS_DIRECT_VARIANT    model_quantized   (model|model_fp16|model_q4|model_q4f16|model_quantized)
# LOTL_TRANSFORMERS_DIRECT_POOLING    last              (last|mean|cls)
# LOTL_TRANSFORMERS_DIRECT_MAXLEN     1024              (seq_len cap — keep modest to avoid RSS blowup)

# Gemini embed throttling (only if LOTL_EMBED_PROVIDER=gemini)
# LOTL_GEMINI_EMBED_BATCH_SIZE   128
# LOTL_GEMINI_EMBED_INTERVAL_MS  60000


# ======================================================================
# Rerank — cross-encoder reranking (optional)
# ======================================================================
# LOTL_MEMORY_RERANK           on                                    (enable rerank; default off)
# LOTL_RERANK_BACKEND          transformers | remote                 (default: transformers)
# LOTL_RERANK_MODE             llm | rerank                          (llm=chat-based; rerank=cross-encoder)
# LOTL_RERANK_PROVIDER         api | url | gemini | ollama | vllm    (remote only)
# LOTL_RERANK_URL              https://...                           (base URL)
# LOTL_RERANK_API_KEY          sk-...                                (optional for local shorthands)
# LOTL_RERANK_MODEL            cross-encoder/ms-marco-MiniLM-L6-v2   (default for local — see src/llm/transformers-rerank.ts)
# LOTL_TRANSFORMERS_RERANK_MAXLEN  512   (tokenizer truncation cap; default 512. Prevents the
#                                          ModernBERT-class OOM where uncapped 8192-token context
#                                          allocated 67 GB for a single MatMul. Raise only if you
#                                          know the reranker needs >512 tokens.)
# LOTL_RERANK_STRONG_SIGNAL_SKIP  on                                 (skip rerank when vec/fts agree strongly)
# LOTL_TRANSFORMERS_RERANK       Xenova/ms-marco-MiniLM-L-6-v2       (composite alias — local rerank model)
# LOTL_TRANSFORMERS_RERANK_DTYPE q8
# LOTL_TRANSFORMERS_RERANK_FILE  (optional)
# LOTL_TRANSFORMERS_RERANK_MODEL Xenova/ms-marco-MiniLM-L-6-v2


# ======================================================================
# Query expansion (optional, improves recall on vague queries)
# ======================================================================
# LOTL_QUERY_EXPANSION_PROVIDER  api | url | gemini | ollama | vllm
# LOTL_QUERY_EXPANSION_URL       https://...
# LOTL_QUERY_EXPANSION_API_KEY   sk-...                              (optional for local shorthands)
# LOTL_QUERY_EXPANSION_MODEL     qwen2.5-7b-instruct                 (any OpenAI-compat chat model)


# ======================================================================
# Memory — recall tuning, decay, knowledge graph
# ======================================================================
# LOTL_MEMORY_KG               on         (enable KG fact injection on weak recall; default off)
# LOTL_MEMORY_MMR              session    (session-level MMR diversification; default off — the
#                                          code checks === "session", NOT === "on")
# LOTL_MEMORY_EXPAND           keywords | entities | none
#                                         (zero-LLM query expansion. **Default: keywords**.
#                                          Set "none" (or any other value) to disable expansion.)
# LOTL_MEMORY_RERANK           on         (enable cross-encoder rerank; default off.
#                                          Regresses on current RRF pipeline until score
#                                          normalization is implemented — src/store/constants.ts:67-74.)
# LOTL_MEMORY_SCOPE_NORM       rank       (per-scope rank normalization; default off — the code
#                                          checks === "rank", NOT === "on")
# LOTL_MEMORY_SYNONYMS         off        (disable the default-on BM25 synonym expansion.
#                                          Synonyms are ON by default via MEMORY_SYNONYMS map in
#                                          src/store/constants.ts. Setting =on is a no-op.)
# LOTL_MEMORY_LHASH            on         (L# cache hierarchy L0/L1/L2 blend — default off.
#                                          Confirmed to CRASH LoCoMo R@5 to 15.5% on flag sweep
#                                          2026-04-19 — Phase 4 delete candidate.)
# LOTL_MEMORY_RRF_W_BM25       0.9        (BM25 weight in RRF fusion; default 0.9)
# LOTL_MEMORY_RRF_W_VEC        0.1        (vector weight in RRF fusion; default 0.1.
#                                          Swept 0.9/0.1, 0.7/0.3, 0.3/0.7, 0.1/0.9 at n=500 LME
#                                          2026-04-18/19: 0.9/0.1 remains optimal. 0.3/0.7 and
#                                          1/9 crash unless paired with LOTL_VEC_MIN_SIM=0.0.)


# ======================================================================
# Recall pipeline
# ======================================================================
# LOTL_RECALL_RAW              on        (skip post-fusion boosts — eval baselines only)
# LOTL_RECALL_NO_TOUCH         on        (skip the recall-time access_count increment.
#                                          Sweep A/Bs sharing a DB accumulate touches from
#                                          earlier configs; enabling this prevents the bias.
#                                          Production: leave off, touches drive decay/promotion.)
# LOTL_RECALL_KG               on        (KG subject-triple injection into pool)
# LOTL_RECALL_KG_RAW           on        (raw KG triples without filtering)
# LOTL_RECALL_MMR              on        (MMR diversity rerank in recall — flat on LME)
# LOTL_RECALL_MMR_LAMBDA       0.85      (MMR lambda — higher = more relevance, less diversity)
# LOTL_RECALL_PROFILE          on        (per-stage timing profile to stderr)
# LOTL_RECALL_DIVERSIFY        on        (inter-session diversification)
# LOTL_RECALL_REFLECT          on        (post-retrieval LLM reflection on pool)
# LOTL_REFLECT_TOP_K           10        (max memories fed to reflection step)
# LOTL_REFLECT_MAX_CHARS       800       (per-memory char cap during reflection)


# ======================================================================
# Ingest — eval-harness ablations (guards optional preprocessing)
# ======================================================================
# These are read by evaluate/*/eval.mts but not by the runtime src/. They gate
# whether the eval harness invokes extractAndStore / extractReflections /
# consolidateEntityFacts / per-turn storage. Default = all enabled.
# Set =off in the sweep scripts for simpler baseline timing.
# LOTL_INGEST_EXTRACTION       on|off
# LOTL_INGEST_REFLECTIONS      on|off
# LOTL_INGEST_SYNTHESIS        on|off
# LOTL_INGEST_PER_TURN         on|off
# LOTL_INGEST_USER_ONLY        on|off    (L1: user turns only at embed time)
# LOTL_INGEST_BATCH_EXTRACT    on|off
# LOTL_INGEST_SESSION_AS_MEMORY  on|off


# ======================================================================
# Chunking / Vector floor
# ======================================================================
# LOTL_CHUNK_SIZE_TOKENS       512   (default chunk size in tokens)
# LOTL_CHUNK_WINDOW_TOKENS     64    (overlap window)
# LOTL_VEC_MIN_SIM             0.1   (fixed cosine floor — recommended, overrides adaptive)
# LOTL_STRICT_DIM_MISMATCH     on    (fail-loud on dim mismatch between model and existing DB)


# ======================================================================
# General
# ======================================================================
# LOTL_CONFIG_DIR              ~/.config/qmd      (config location override)
# LOTL_LOCAL                   on                 (force local-only mode)
# LOTL_SKILL_BASE              /path/to/skills    (custom skill install base)
# LOTL_EDITOR_URI              vscode://file/%s   (custom editor URI template)
# LOTL_LLM_CACHE               /path/to/cache     (LLM response cache, reproducibility)
# LOTL_LLM_CACHE_PATH          /path/to/cache     (alias)
# LOTL_TIMEOUT_MS              30000              (default request timeout)


# ======================================================================
# Eval-only (LOTL_LOCOMO_/LOTL_ANSWER_/LOTL_POE_/LOTL_LME_/LOTL_EVAL_)
# ======================================================================
# LOTL_ANSWER_TOP_K            10     (LongMemEval: memories fed to generator; Mem0 paper default)
# LOTL_ANSWER_MAX_CHARS        6000   (LongMemEval: per-memory char cap before prompt assembly)
# LOTL_LOCOMO_ANSWER_TOP_K     10     (LoCoMo: memories fed to generator)
# LOTL_LME_WORKERS             2      (parallel workers for LongMemEval eval loop)
# LOTL_LOCOMO_WORKERS          1      (parallel workers for LoCoMo eval loop — must match LM Studio `parallel` slots)
# LOTL_PROMPT_RULES            v11    (answer prompt version — v11 default, v13 minimal for --judge, v14 = 7-step CoT ported from locomo-audit repo)
# LOTL_POE_MODEL               gpt-4o-mini  (Poe endpoint model — override for --llm poe runs)
# LOTL_EVAL_PARTIAL_EVERY      10     (save partial results every N questions)
# LOTL_SKIP_PREFLIGHT          on     (skip API quota preflight probe — speeds up ad-hoc runs)
# LOTL_JUDGE_MAX_TOKENS        96     (judge output cap; raised to 768 automatically for lmstudio — thinking models burn reasoning tokens)
# LOTL_ANSWER_CACHE            on     (persist every generated answer to answer-cache/ — enables judge replay; set to "off" to disable)
# LOTL_ANSWER_CACHE_DIR        evaluate/longmemeval/answer-cache  (where persisted answers live)
#
# LM Studio local LLM (OpenAI-compatible) — no API key required, use any placeholder.
# LOTL_LMSTUDIO_HOST           10.0.0.105:1234                   (host:port of LM Studio server)
# LOTL_LMSTUDIO_KEY            lm-studio                         (placeholder — askLLM checks for non-empty)
# LOTL_LMSTUDIO_GEN_MODEL      meta-llama-3.1-8b-instruct        (model loaded for answer generation)
# LOTL_LMSTUDIO_JUDGE_MODEL    qwen/qwen3.6-35b-a3b              (model loaded for judge pass — use two-pass script)


# ======================================================================
# API keys (per-provider — REQUIRED for respective providers)
# ======================================================================
# OPENAI_API_KEY=sk-...              (for LOTL_EMBED_PROVIDER=api with OpenAI)
# GOOGLE_API_KEY=AIza...             (for LOTL_EMBED_PROVIDER=gemini / --llm gemini)
# POE_API_KEY=psk_...                (for --llm poe / --judge poe)
# MINIMAX_API_KEY=eyJ...             (for --llm minimax)


# ======================================================================
# Local-LLM provider shorthands (OpenAI-compatible endpoints)
# ======================================================================
# Ollama                → QMD_{OP}_PROVIDER=ollama     (url default http://localhost:11434/v1)
# vLLM                  → QMD_{OP}_PROVIDER=vllm       (url default http://localhost:8000/v1)
# Lemonade (AMD)        → QMD_{OP}_PROVIDER=lemonade   (url default http://localhost:8000/api/v1)
# LM Studio             → QMD_{OP}_PROVIDER=lm-studio  (url default http://localhost:1234/v1)
#
# All of the above accept API_KEY being unset or any placeholder.
# Override the URL with QMD_{OP}_URL if you've remapped the server port.
#
# Example — local query expansion via Ollama:
# LOTL_QUERY_EXPANSION_PROVIDER=ollama
# LOTL_QUERY_EXPANSION_MODEL=qwen2.5:7b-instruct
