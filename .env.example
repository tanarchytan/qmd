# QMD Environment Variables
# Copy to ~/.config/qmd/.env and fill in your API keys.
# Loaded automatically at startup — no need to source.

# ============================================================
# Local LLM control
# ============================================================
#
# QMD_LOCAL=no              Disable local node-llama-cpp entirely (remote-only mode)
# QMD_LLAMA_BUILD=auto      Allow cmake builds if prebuilt binaries fail
#                            (default: prebuilt only, no cmake)

# ============================================================
# Provider modes
# ============================================================
#
# Each operation (embed, rerank, query expansion) is configured independently
# with 4 env vars:
#
#   QMD_{OP}_PROVIDER=   local | api | url | gemini
#   QMD_{OP}_API_KEY=    Bearer token
#   QMD_{OP}_URL=        see below
#   QMD_{OP}_MODEL=      model name
#
# Provider types:
#   local   — use local GGUF model (default, no key needed)
#   api     — OpenAI-compatible base URL. Paths auto-appended:
#             URL + /embeddings, URL + /rerank, URL + /chat/completions
#   url     — direct endpoint URL, used as-is (nothing appended)
#   gemini  — Google Gemini (x-goog-api-key auth, different format)
#
# Shorthand aliases (set provider + default URL automatically):
#   siliconflow → api + https://api.siliconflow.cn/v1
#   openai      → api + https://api.openai.com/v1
#   zeroentropy → url + per-operation ZeroEntropy endpoints
#   dashscope   → url + https://dashscope.aliyuncs.com/compatible-api/v1/reranks

# ============================================================
# Example A: ZeroEntropy embed + rerank (one API key)
# ============================================================
#
# QMD_LOCAL=no
# QMD_EMBED_PROVIDER=zeroentropy
# QMD_EMBED_API_KEY=ze-your-key
# QMD_EMBED_MODEL=zembed-1
# QMD_RERANK_PROVIDER=zeroentropy
# QMD_RERANK_API_KEY=ze-your-key
# QMD_RERANK_MODEL=zerank-2

# ============================================================
# Example B: Nebius embed + query expansion, ZeroEntropy rerank
# ============================================================
#
# QMD_LOCAL=no
# QMD_EMBED_PROVIDER=api
# QMD_EMBED_API_KEY=nebius-key
# QMD_EMBED_URL=https://api.studio.nebius.ai/v1
# QMD_EMBED_MODEL=Qwen3-Embedding-8B
# QMD_RERANK_PROVIDER=zeroentropy
# QMD_RERANK_API_KEY=ze-key
# QMD_RERANK_MODEL=zerank-2
# QMD_QUERY_EXPANSION_PROVIDER=api
# QMD_QUERY_EXPANSION_API_KEY=nebius-key
# QMD_QUERY_EXPANSION_URL=https://api.studio.nebius.ai/v1
# QMD_QUERY_EXPANSION_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# ============================================================
# Example C: SiliconFlow all three operations
# ============================================================
#
# QMD_LOCAL=no
# QMD_EMBED_PROVIDER=siliconflow
# QMD_EMBED_API_KEY=sk-your-key
# QMD_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
# QMD_RERANK_PROVIDER=siliconflow
# QMD_RERANK_API_KEY=sk-your-key
# QMD_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# QMD_RERANK_MODE=rerank
# QMD_QUERY_EXPANSION_PROVIDER=siliconflow
# QMD_QUERY_EXPANSION_API_KEY=sk-your-key
# QMD_QUERY_EXPANSION_MODEL=zai-org/GLM-4.5-Air

# ============================================================
# Embedding
# ============================================================

# QMD_EMBED_PROVIDER=local         # local | api | url | siliconflow | openai | zeroentropy
# QMD_EMBED_API_KEY=your-key
# QMD_EMBED_URL=                   # api: base URL (e.g. https://api.studio.nebius.ai/v1)
#                                  # url: full endpoint (e.g. https://api.zeroentropy.dev/v1/models/embed)
# QMD_EMBED_MODEL=                 # e.g. Qwen3-Embedding-8B, zembed-1
# QMD_EMBED_DIMENSIONS=            # Any positive integer (e.g. 2560, 4096, 1536)

# ============================================================
# Reranking
# ============================================================

# QMD_RERANK_PROVIDER=local        # local | api | url | siliconflow | openai | zeroentropy | dashscope | gemini
# QMD_RERANK_API_KEY=your-key
# QMD_RERANK_URL=                  # api: base URL → appends /rerank  |  url: full endpoint used as-is
# QMD_RERANK_MODEL=                # e.g. BAAI/bge-reranker-v2-m3, zerank-2
# QMD_RERANK_MODE=rerank           # rerank = dedicated rerank API (default for url provider)
#                                  # llm    = chat model reranking (default for api/gemini)

# ============================================================
# Query expansion
# ============================================================

# QMD_QUERY_EXPANSION_PROVIDER=local   # local | api | url | siliconflow | openai | gemini
# QMD_QUERY_EXPANSION_API_KEY=your-key
# QMD_QUERY_EXPANSION_URL=             # api: base URL → appends /chat/completions  |  url: full endpoint
# QMD_QUERY_EXPANSION_MODEL=           # e.g. zai-org/GLM-4.5-Air, meta-llama/Meta-Llama-3.1-70B-Instruct

# ============================================================
# Provider reference
# ============================================================
#
# ZeroEntropy  (https://zeroentropy.dev)
#   Embed:   https://api.zeroentropy.dev/v1/models/embed   (or eu-api.zeroentropy.dev)
#   Rerank:  https://api.zeroentropy.dev/v1/models/rerank
#   Models:  zembed-1 (embed), zerank-2 (rerank)
#
# SiliconFlow  (https://cloud.siliconflow.cn — free tier)
#   Base URL: https://api.siliconflow.cn/v1  (or https://api.siliconflow.com/v1 outside China)
#
# Nebius  (https://studio.nebius.ai)
#   Base URL: https://api.studio.nebius.ai/v1
#   Recommended embed model: Qwen3-Embedding-8B
#
# Gemini  (https://ai.google.dev — free tier: 15 RPM / 1M tokens/day)
#   Base URL: https://generativelanguage.googleapis.com
#   Model: gemini-2.5-flash
#
# OpenAI / any OpenAI-compatible endpoint
#   Base URL: https://api.openai.com/v1

# ============================================================
# Chunking  (sensible defaults)
# ============================================================

# QMD_CHUNK_SIZE_TOKENS=900        # tokens per chunk (default 900)
# QMD_CHUNK_WINDOW_TOKENS=200      # search window for break points (default 200)
# QMD_EMBED_BATCH_SIZE=32          # embedding batch size

# ============================================================
# Scoring tunables  (advanced — defaults work well)
# ============================================================
#
# QMD_RERANK_CANDIDATE_LIMIT=40    # max docs sent to reranker
# QMD_RRF_K=60                     # RRF smoothing constant (higher = flatter ranking)
# QMD_WEIGHT_FTS=2.0               # BM25 list weight in RRF fusion
# QMD_WEIGHT_VEC=1.0               # vector list weight in RRF fusion
# QMD_BLEND_RRF_TOP3=0.75          # RRF/rerank blend for rank 1-3 (higher = trust RRF more)
# QMD_BLEND_RRF_TOP10=0.60         # blend for rank 4-10
# QMD_BLEND_RRF_REST=0.40          # blend for rank 11+
# QMD_STRONG_SIGNAL_MIN_SCORE=0.85 # BM25 score to skip expansion
# QMD_STRONG_SIGNAL_MIN_GAP=0.15   # gap between top-1 and top-2 to skip expansion

# ============================================================
# Paths  (auto-detected, override if needed)
# ============================================================

# QMD_CONFIG_DIR=~/.config/qmd    # config directory (index.yml location)
# XDG_CACHE_HOME=~/.cache         # cache dir (db at $XDG_CACHE_HOME/qmd/index.sqlite)
# QMD_SQLITE_VEC_PATH=            # sqlite-vec extension path (auto-detected)
