        "type": "boolean",
        "default": true
      },
      "autoCapture": {
        "type": "boolean",
        "default": true
      },
      "topK": {
        "type": "number",
        "default": 5
      },
      "scope": {
        "type": "string",
        "default": "global"
      },
      "dbPath": {
        "type": "string",
