            "description": "rerank | llm"
          }
        }
      },
      "queryExpansion": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "description": "api | url | siliconflow | openai | gemini"
          },
          "apiKey": {
            "type": "string"
          },
